    "from langchain_ollama import ChatOllama\n",
    "from langchain_core.messages import HumanMessage\n",
    "#调用本地大模型，省略base_url、api_key等参数\n",
    "llm = ChatOllama(\n",
    "    model =\"qwen3.5:9b\"\n",
    ")\n",
    "messages = [\n",
    "    HumanMessage(content=\"你好,请介绍一下你自己\"),\n",
    "]\n",
    "llm.invoke(messages)"
   ]
